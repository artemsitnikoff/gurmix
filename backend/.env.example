# «Нейро-шеф Гурмикс» backend — пример окружения. Скопируйте в .env.

# Claude OAuth (опционально — если нет, полагаемся на залогиненный `claude` CLI)
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_REFRESH_TOKEN=

# База знаний (SQLite)
DATABASE_PATH=base/gurmix.db

# Логирование
LOG_LEVEL=INFO

# Квоты (подстраховка Pro-аккаунта)
QUOTA_LIMIT=30
QUOTA_PERIOD=day

# Админка (basic-auth). Без ADMIN_PASS админка отдаёт 503.
ADMIN_USER=admin
ADMIN_PASS=

# Claude CLI (по умолчанию: Opus 4.8 на интент и на ответ;
# для скорости интента можно поставить CLAUDE_INTENT_MODEL=claude-haiku-4-5)
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_INTENT_MODEL=claude-opus-4-8
# CLAUDE_CLI_PATH=claude
# CLAUDE_CLI_MAX_CONCURRENT=4
