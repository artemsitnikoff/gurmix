data/
base/

# Python-кэши
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Секреты
.env

# Логи
**/*.log
**/logs/

# Прочее
.git/
docs/
