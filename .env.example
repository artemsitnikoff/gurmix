# «Нейро-шеф Гурмикс» — окружение для ДЕПЛОЯ (docker compose). Скопируй в .env.
# (Для локального запуска без Docker есть отдельный backend/.env.example.)

# ── Порт приложения ───────────────────────────────────────────────────────────
# Нестандартный по умолчанию (на проде много чего занято). Одна переменная задаёт
# и host-, и container-порт. Если 8420 занят — поменяй здесь, и всё переедет.
APP_PORT=8420

# ── Claude OAuth (Pro-подписка, НЕ платный API) ───────────────────────────────
# На проде токен берётся из data/.claude_token.json (симлинк на ArkadiyJarvis/data),
# поэтому эти переменные обычно можно оставить пустыми. Заполни при первом деплое,
# если общего токена ещё нет — он запишется в data/.claude_token.json и дальше
# обновляется автоматически.
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_REFRESH_TOKEN=
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_INTENT_MODEL=claude-opus-4-8     # для скорости интента: claude-haiku-4-5
# CLAUDE_CLI_MAX_CONCURRENT=4

# ── База знаний ───────────────────────────────────────────────────────────────
DATABASE_PATH=base/gurmix.db

# ── Логирование ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Лимиты на пользователя (анонимная сессия + IP; подстраховка Pro-аккаунта) ──
QUOTA_LIMIT=30
QUOTA_PERIOD=day            # day | week | month

# ── Админка (basic-auth). БЕЗ ADMIN_PASS админка отдаёт 503 ────────────────────
ADMIN_USER=admin
ADMIN_PASS=

# ── CORS (для отдельного фронта; при single-origin деплое не нужно) ────────────
# CORS_ORIGINS=https://bot.gurmix.ru
